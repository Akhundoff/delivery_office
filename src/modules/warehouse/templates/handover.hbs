          <tr>
            <th colspan='5'>
              <div class='check-number'>FX{{user.id}} </div>
            </th>
          </tr>
        </thead>

        <tbody>
          <tr>
            <td colspan='5'><b>Anbardar: {{warehouseman}} </b></td>
          </tr>
          <tr>
            <td colspan='5'><b>Kassir: {{cashier.fullName}} </b></td>
          </tr>
          <tr>
            <td colspan='5'><b>Müştəri: {{user.fullName}} </b></td>
          </tr>
          <tr>
            <td colspan='5'><b>Tarix: {{checkDate}} </b></td>
          </tr>
        </tbody>

        <tbody class='check-items'>
          <tr>
            <th colspan='5' style='text-align: center'>Bağlamalar</th>
          </tr>
          <tr>
            <th style='width: 1px'>No</th>
            <th>İzləmə kodu</th>
            <th style='width: 1px'>Trendyol</th>
            <th>Çəki</th>
            <th>Yeşik</th>
          </tr>
          {{#each declarations}}
            <tr>
              <td rowspan='2'>
                {{addOne @index}}
              </td>
              <td>
                {{#if (eq trendyol 2)}}
                  {{globalTrackCode}}
                {{else if partnerId}}
                  {{globalTrackCode}}
                {{else}}
                  {{trackCode}}
                {{/if}}
              </td>
              <td class='text-center'>
                {{#if (eq trendyol 1)}}
                  &#x2713;
                {{else}}
                  &#x2715;
                {{/if}}
              </td>
              <td>
                {{weight}}
              </td>
              <td>
                {{box.name}}
              </td>
            </tr>
            <tr>
              <td class='text-center' colspan='4'>
                {{shop}}
              </td>
            </tr>
          {{/each}}
        </tbody>

      </table>
      <table class='check-table'>
        <tbody class='check-items'>
          <tr>
            <td>No</td>
            <td>Kiçik paket</td>
            <td>Orta paket</td>
            <td>Böyük paket</td>
          </tr>
          <tr>
            <td>1</td>
            <td>{{packages.smallPackage}}</td>
            <td>{{packages.mediumPackage}}</td>
            <td>{{packages.bigPackage}}</td>
          </tr>
        </tbody>
        <tfoot>
          <tr>
            <th colspan='5' class='py-6'>Təhvil aldım: _________ </th>
          </tr>
          <tr>
            <th colspan='5'>
              <div class='barcode-area'>
                <div class='barcode-wrapper'>
                  <svg class='barcode' id='barcode-{{handoverTaskId}}'></svg>
                </div>
              </div>
            </th>
          </tr>
        </tfoot>
      </table>
    </div>
    <script src='https://cdn.jsdelivr.net/npm/jsbarcode@3.11.0/dist/JsBarcode.all.min.js'></script>
    <script>
      document.addEventListener('DOMContentLoaded', (event) => { JsBarcode('#barcode-{{handoverTaskId}}', '{{handoverTaskId}}', { height: 40, width: 2, displayValue: false }); }); (function() {
      setTimeout(function () { window.print(); }, 500); var afterPrint = function() { var delay = 500; setTimeout(function(){ window.close(); }, delay); }; if (window.matchMedia) { var mediaQueryList
      = window.matchMedia('print'); mediaQueryList.addListener(function(mql) { if (!mql.matches) { afterPrint(); } }); } window.onafterprint = afterPrint; }());
    </script>
  </body>
